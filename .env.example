# ArcSphere3D — root .env example
# Copy to .env and adjust for local dev. NEVER commit .env.

# === backend ===
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# JWT — replace with `openssl rand -hex 32` in real envs
JWT_SECRET=change-me-to-a-32-byte-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=60

# DB (used post-MVP — MVP is in-memory)
DATABASE_URL=postgresql+psycopg://arc:arc@localhost:5432/arcsphere3d

# Object storage (MinIO compose default)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=arc
S3_SECRET_KEY=arc-secret
S3_BUCKET=arcsphere3d
S3_REGION=us-east-1

# === frontend ===
VITE_API_BASE_URL=http://localhost:8000

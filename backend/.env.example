APP_ENV=development
APP_NAME=ArcSphere3D
APP_VERSION=0.1.0

# CORS
CORS_ORIGINS=http://localhost:5173

# Database (set to a real DSN in production)
DATABASE_URL=postgresql+psycopg://arc:arc@localhost:5432/arcsphere3d

# JWT (HS256 for dev; switch to RS256 in production)
JWT_SECRET=change-me-please-32+chars-minimum-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=60

# Storage (MinIO)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=arc
S3_SECRET_KEY=arc-secret
S3_BUCKET=arcsphere3d
S3_REGION=us-east-1

# Logging
LOG_LEVEL=INFO

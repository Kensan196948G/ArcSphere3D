# ADR-0004 #3: fail-closed Secret supply for production.
#
# The base ships a placeholder Secret (stringData with CHANGE_ME_* values) for
# dev quickstart. In production the Secret MUST come from a real secret store
# so that no credential ever lives in git.
#
# This file is an EXAMPLE (.example, not referenced by kustomization.yaml)
# because it depends on the external-secrets-operator CRDs, which are not part
# of this repo and would fail `kustomize build` / `kubeconform`. To use it:
#   1. install external-secrets-operator on the cluster,
#   2. configure a ClusterSecretStore (vault / AWS SM / GCP SM / Azure KV),
#   3. drop this file into the overlay, reference it in kustomization resources,
#   4. REMOVE secret.yaml from the rendered output (patch it out or use a
#      components/ that excludes the base Secret) so the placeholder never wins.
---
apiVersion: external-secrets.io/v1 # v1beta1 is removed in ESO v0.17+; use v1
kind: ExternalSecret
metadata:
  name: arcsphere3d-secret
  namespace: arcsphere3d
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: arcsphere3d-store # ClusterSecretStore / SecretStore name
    kind: ClusterSecretStore
  target:
    name: arcsphere3d-secret # produces the same Secret name the workloads expect
    creationPolicy: Owner
  data:
    - secretKey: POSTGRES_USER
      remoteRef: { key: arcsphere3d/postgres, property: user }
    - secretKey: POSTGRES_PASSWORD
      remoteRef: { key: arcsphere3d/postgres, property: password }
    - secretKey: S3_ROOT_USER
      remoteRef: { key: arcsphere3d/minio-root, property: user }
    - secretKey: S3_ROOT_PASSWORD
      remoteRef: { key: arcsphere3d/minio-root, property: password }
    - secretKey: S3_ACCESS_KEY
      remoteRef: { key: arcsphere3d/minio-app, property: access_key }
    - secretKey: S3_SECRET_KEY
      remoteRef: { key: arcsphere3d/minio-app, property: secret_key }
    - secretKey: REDIS_PASSWORD
      remoteRef: { key: arcsphere3d/redis, property: password }
    - secretKey: JWT_PRIVATE_KEY_PEM
      remoteRef: { key: arcsphere3d/jwt, property: private_key }
    - secretKey: JWT_PUBLIC_KEY_PEM
      remoteRef: { key: arcsphere3d/jwt, property: public_key }

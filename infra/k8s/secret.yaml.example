# DO NOT COMMIT WITH REAL VALUES — copy to secret.yaml and populate
# Generate base64 values with: echo -n "value" | base64
apiVersion: v1
kind: Secret
metadata:
  name: arcsphere3d-secrets
  namespace: arcsphere3d
type: Opaque
data:
  POSTGRES_PASSWORD: YXJjLXNlY3JldA==      # replace: echo -n "your-pg-password" | base64
  POSTGRES_USER: YXJj                        # replace: echo -n "arc" | base64
  S3_ACCESS_KEY: YXJj                        # replace: echo -n "minio-access-key" | base64
  S3_SECRET_KEY: YXJjLXNlY3JldA==           # replace: echo -n "minio-secret-key" | base64
  JWT_PRIVATE_KEY_PEM: |                     # replace with RS256 private key base64
    BASE64_ENCODED_PEM_HERE
  JWT_PUBLIC_KEY_PEM: |                      # replace with RS256 public key base64
    BASE64_ENCODED_PEM_HERE
